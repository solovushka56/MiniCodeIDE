<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout

    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.cardview.widget.CardView
        android:id="@+id/compilePanel"
        android:visibility="invisible"

        app:cardCornerRadius="15dp"
        android:backgroundTint="@color/violet_light"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:minHeight="300dp"

        android:layout_width="match_parent"
        android:layout_height="400dp"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            android:layout_margin="8dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:gravity="right"
                android:contentDescription="compile options panel"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ProgressBar
                    android:indeterminate="true"
                    android:id="@+id/compileProgress"
                    android:visibility="invisible"
                    android:indeterminateTint="@color/light_blue_400"
                    android:padding="5dp"
                    android:background="@drawable/button_rect_common"
                    android:backgroundTint="@color/violet_average"
                    android:layout_margin="5dp"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"/>

                <Space
                    android:layout_weight="1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/runCodeButton"
                    android:text="Run"
                    android:layout_margin="2dp"
                    android:backgroundTint="@color/violet_muted"
                    app:cornerRadius="8dp"
                    app:iconGravity="textEnd"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"/>

                <ImageButton
                    android:id="@+id/hideCompilePanelBtn"
                    android:scaleX="0.8"
                    android:scaleY="0.8"
                    app:rippleColor="@color/orange_light"
                    android:background="@drawable/ripple_shape"
                    android:backgroundTint="@color/violet"
                    android:padding="10dp"
                    android:src="@drawable/x_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                </ImageButton>

            </LinearLayout>

            <androidx.cardview.widget.CardView
                app:cardCornerRadius="10dp"
                app:cardBackgroundColor="@color/violet_average"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <EditText
                    android:gravity="top"
                    android:textSize="15sp"
                    android:layout_margin="10dp"
                    android:id="@+id/compileConsole"
                    android:textColor="@color/white"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>