<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/dark_fade_bg"
    android:backgroundTintMode="src_over"
    tools:context=".presentation.ui.activity.MenuActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="15dp"
        app:layout_constraintBottom_toTopOf="@id/navigationView"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="15dp">

        <FrameLayout
            android:id="@+id/mainFragmentLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navigationView"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_marginTop="15dp"
        android:layout_marginLeft="15dp"
        android:layout_marginRight="15dp"
        android:layout_marginBottom="5dp"
        android:background="@drawable/group_rect_black"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/tutorialsButton"
            style="@style/CustomNavMaterialButtonInactive"
            android:contentDescription="@null"
            app:icon="@drawable/coffee"
            app:iconGravity="top"
            app:iconPadding="0dp"
            android:padding="6dp"
            android:text="info"
            android:textColor="@color/violet_light"
            android:textAllCaps="false"
            app:iconSize="28dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/projectsButton"
            style="@style/CustomNavMaterialButtonActive"
            android:contentDescription="@null"
            app:icon="@drawable/home"
            app:iconGravity="top"
            app:iconPadding="0dp"
            android:padding="6dp"
            android:text="home"
            android:textAllCaps="false"
            android:textColor="@color/blue_light"
            app:iconSize="28dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/settingsButton"
            style="@style/CustomNavMaterialButtonInactive"
            android:contentDescription="@null"
            app:icon="@drawable/settings_menu"
            app:iconGravity="top"
            app:iconPadding="0dp"
            android:padding="6dp"
            android:text="prefs"
            android:textColor="@color/violet_light"
            android:textAllCaps="false"
            app:iconSize="28dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>